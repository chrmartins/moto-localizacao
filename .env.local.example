# Supabase — copie para .env.local e preencha com as chaves do seu projeto.
# Painel do Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-ou-publishable-key

# Opcional: URL base do site (usada em redirects de auth em produção).
# Em dev pode deixar em branco.
NEXT_PUBLIC_SITE_URL=
